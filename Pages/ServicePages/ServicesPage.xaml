<Page x:Class="Telecom.Pages.ServicePages.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Telecom.Pages.ServicePages"
      xmlns:services="clr-namespace:Telecom.Services"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#FFFFFF" Title="ServicesPage" IsVisibleChanged="Page_IsVisibleChanged">

    <Border Grid.Row="1" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Услуги"
                       FontSize="14pt"
                       FontWeight="DemiBold" 
                       Foreground="#111827"
                       Padding="5"
                       Grid.Row="0"/>

            <DockPanel Grid.Row="1" LastChildFill="False">
                <Button x:Name="ButtonAdd" 
                        Content="➕ Добавить услугу"
                        DockPanel.Dock="Left"
                        Background="#10B981"
                        Foreground="#FFFFFF"
                        Margin="5,0"
                        Click="ButtonAdd_Click"
                        Style="{StaticResource PrimaryButtonTheme}"/>

                <TextBox x:Name="SearchBox"
                         DockPanel.Dock="Right"
                         Margin="5"
                         Width="250"
                         Tag="🔍 Поиск"
                         TextChanged="SearchBox_TextChanged"
                         Style="{StaticResource ModernTextBox}"/>
            </DockPanel>

            <DataGrid x:Name="DataGridServices"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      RowBackground="#FFFFFFFF"
                      AlternatingRowBackground="#F4F7F9"
                      Grid.Row="2"
                      Margin="0,5,0,0"
                      Style="{StaticResource ModernDataGrid}">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Номер" 
                                        Width="0.5*"
                                        Binding="{Binding ServiceId, StringFormat=\{0:D4\}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="TextAlignment" Value="Left"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Наименование" 
                                        Width="*"
                                        Binding="{Binding Name}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="TextAlignment" Value="Left"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Цена" 
                                        Width="0.75*"
                                        Binding="{Binding Price, StringFormat={}{0:N2} ₽}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Left"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="ButtonEdit" 
                                        Content="🖋️"
                                        Background="Transparent"
                                        FontSize="14"
                                        Foreground="#94A3B8"
                                        Visibility="Collapsed"
                                        Click="ButtonEdit_Click"
                                        Style="{StaticResource PrimaryButtonTheme}"/>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Source={x:Static services:UserSessionService.IsAdmin}}" 
                                                 Value="True">
                                        <Setter TargetName="ButtonEdit" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="ButtonDetails" 
                                        Content="🔍"
                                        Background="Transparent"
                                        FontSize="14"
                                        Foreground="#94A3B8"
                                        Visibility="Collapsed"
                                        Click="ButtonEdit_Click"
                                        Style="{StaticResource PrimaryButtonTheme}"/>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Source={x:Static services:UserSessionService.IsMaster}}" 
                                                 Value="True">
                                        <Setter TargetName="ButtonDetails" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Source={x:Static services:UserSessionService.IsDispatch}}" 
                                                 Value="True">
                                        <Setter TargetName="ButtonDetails" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="ButtonDelete"
                                            Content="❌"
                                            FontSize="14"
                                            Foreground="#EF4444"
                                            Visibility="Collapsed"
                                            Click="ButtonDelete_Click"
                                            Style="{StaticResource PrimaryButtonTheme}"/>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Source={x:Static services:UserSessionService.IsAdmin}}" 
                                                 Value="True">
                                        <Setter TargetName="ButtonDelete" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</Page>
