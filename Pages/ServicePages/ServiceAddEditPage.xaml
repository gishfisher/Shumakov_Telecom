<Page x:Class="Telecom.Pages.ServicePages.ServiceAddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Telecom.Pages.ServicePages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ServiceAddEditPage">

    <Border MaxWidth="700"
            VerticalAlignment="Center" HorizontalAlignment="Center"
            Background="#FFFFFF" Width="550">

        <StackPanel Margin="25">

            <StackPanel Orientation="Horizontal">
                <Button x:Name="GoBack"
                        Content="◀️ Назад"
                        Click="GoBack_Click"
                        Foreground="#94A3B8"
                        Margin="5,0,0,0"
                        Style="{StaticResource PrimaryButtonTheme}" Cursor="Hand"/>
                <Label x:Name="LabelTitle"
                       Content="Добавление услуги"
                       FontSize="14pt"
                       Padding="5"
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Foreground="#111827"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Label Content="Наименование"/>
                <TextBox Text="{Binding Name}"
                 Style="{StaticResource ModernTextBox}"/>
                <Label Content="Цена"/>
                <TextBox Text="{Binding Price}"
                     Style="{StaticResource ModernTextBox}"/>
            </StackPanel>

            <StackPanel>
                <Button x:Name="btnAddService"
                        Content="➕ Добавить" 
                        Style="{StaticResource PrimaryButtonTheme}"
                        Margin="0,25,0,10"
                        Background="#10B981"
                        Foreground="#FFFFFF"
                        Click="btnAddService_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Page>
