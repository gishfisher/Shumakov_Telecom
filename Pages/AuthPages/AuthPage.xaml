<Page x:Class="TelecomCompany.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TelecomCompany.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage">

    <Border MaxWidth="400"
            VerticalAlignment="Center" HorizontalAlignment="Center"
            Background="#FFFFFF" Width="350">
        
        <StackPanel Margin="25">

            <Label Content="Аутентификация"
                   FontSize="18pt"
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

            <Label Content="Логин"/>
            <TextBox x:Name="TBLogin"
                     Style="{StaticResource ModernTextBox}"/>


            <Label Content="Пароль"/>
            <PasswordBox x:Name="PBPassword"
                         Style="{StaticResource ModernPasswordBox}"/>

            <StackPanel>

                <Button x:Name="ButtonLogin" 
                        Content="Вход"
                        Margin="0,25,0,0"
                        Click="Login_Click"
                        Background="#2563EB"
                        Foreground="#FFFFFF"
                        Style="{StaticResource PrimaryButtonTheme}"/>

                <!--<Button x:Name="btnCreateAcc" 
                        Content="Registration"
                        Background="Transparent" 
                        Foreground="#4B5563" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Click="Registration_Click"
                        Visibility="Collapsed"/>-->

            </StackPanel>
        </StackPanel>
    </Border>
</Page>
